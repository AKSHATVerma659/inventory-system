# Production: your deployed API (include /api)
VITE_API_BASE_URL=https://your-api.example.com/api

# Optional: WebSocket origin if you use real-time features (no /api suffix)
VITE_WS_URL=https://your-api.example.com

# Local dev: omit these or use:
# VITE_API_BASE_URL=http://localhost:5000/api
# VITE_WS_URL=http://localhost:5000
